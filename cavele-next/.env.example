# ────────────────────────────────────────────────────────────────
# Cavele Digital — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEXT_PUBLIC_* vars are exposed to the browser (safe for public IDs
# like analytics + a public webhook). Never put real secrets in these.
# ────────────────────────────────────────────────────────────────

# Production site origin (no trailing slash). Drives canonical URLs,
# OpenGraph, sitemap.xml and robots.txt.
NEXT_PUBLIC_SITE_URL=https://caveledigital.co.za

# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA4_ID=G-CWCNZH1WNC

# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=1325835069529734

# Meta domain verification token (from Business Manager)
NEXT_PUBLIC_FB_DOMAIN_VERIFICATION=99a7mwepsdfslbua2so76dtenh60x4

# Social profile links (public — shown in nav, footer, and admin shortcuts)
NEXT_PUBLIC_FACEBOOK=https://facebook.com/yourpage
NEXT_PUBLIC_INSTAGRAM=https://instagram.com/yourhandle
NEXT_PUBLIC_TIKTOK=https://tiktok.com/@yourhandle
NEXT_PUBLIC_WHATSAPP=https://wa.me/27710836571

# ── Server-only secrets (NOT exposed to the browser) ──
# These must NOT use the NEXT_PUBLIC_ prefix — they stay on the server.

# MongoDB Atlas connection string (Atlas → Connect → Drivers).
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# Database name to use inside the cluster.
MONGODB_DB=cavele

NEXT_PUBLIC_SITE_URL=https://caveledigital.co.za
NEXT_PUBLIC_GA4_ID=G-CWCNZH1WNC
NEXT_PUBLIC_META_PIXEL_ID=1325835069529734
NEXT_PUBLIC_FB_DOMAIN_VERIFICATION=99a7mwepsdfslbua2so76dtenh60x4


NEXT_PUBLIC_TIKTOK=https://www.tiktok.com/@caveledigital?_r=1&_t=ZS-980fZlqkUDw
NEXT_PUBLIC_FACEBOOK=https://www.facebook.com/profile.php?id=61581610660661
NEXT_PUBLIC_INSTAGRAM=https://www.instagram.com/caveledigital/
NEXT_PUBLIC_WHATSAPP=https://wa.me/27710836571

RESEND_API_KEY=
# Verified sender. Use "onboarding@resend.dev" for testing before your domain is verified.
RESEND_FROM=
# Inbox that receives new-lead notifications (defaults to the site email).
LEAD_NOTIFY_EMAIL
# Cloudinary — media storage/CDN (Dashboard → Product Environment Credentials)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Public cloud name for building delivery URLs in the browser (same value as CLOUDINARY_CLOUD_NAME).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Admin dashboard password (6+ chars) — protects /admin (leads & quotes).
ADMIN_PASSWORD=

# JWT_SECRET=
